# Supabase Configuration
# Replace these with your Supabase project credentials if you want cloud sync & multi-device login.
# If left blank, the app will fall back to local browser storage (LocalStorage).
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Groq API Configuration (Fast, Free AI Parsing & Vision)
# Get your free key from Groq Console (https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Gemini API Configuration (Alternative AI Provider)
# Required for Natural Language parsing, conversational AI wallet assistant, and receipt scanning.
# Get your API key from Google AI Studio (https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key

# NextAuth Configuration
# Set this to a long random secret key for JWT session encryption (e.g. openssl rand -base64 32)
# Both NEXTAUTH_SECRET and AUTH_SECRET are supported
NEXTAUTH_SECRET=your-nextauth-secret-key
# Set this to the base URL of your application (e.g. http://localhost:3000/ in development)
NEXTAUTH_URL=http://localhost:3000/

# Google OAuth Configuration (Optional, for Google Sign In)
# Both sets of variables are supported (GOOGLE_CLIENT_ID / AUTH_GOOGLE_ID and GOOGLE_CLIENT_SECRET / AUTH_GOOGLE_SECRET)
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

